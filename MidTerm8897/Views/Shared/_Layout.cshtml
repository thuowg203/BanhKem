<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MidTerm8897</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MidTerm8897.styles.css" asp-append-version="true" />
    <style>
        .custom-navbar {
            background-color: #222;
            padding: 8px 24px;
            border-radius: 4px;
            display: flex;
            gap: 32px;
        }

            .custom-navbar a {
                color: #bbb;
                font-size: 16px;
                text-decoration: none;
                font-weight: 400;
                padding: 8px 0;
                transition: color 0.2s ease-in-out;
            }

                .custom-navbar a.active,
                .custom-navbar a:hover {
                    color: #fff;
                    font-weight: 600;
                }

        footer {
            margin-top: 60px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">MidTerm8897</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="custom-navbar">
                        <a href="@Url.Action("Index", "Doctor")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" ? "active" : "")">Doctors</a>
                        <a href="@Url.Action("Index", "Patient")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")">Patients</a>
                        <a href="@Url.Action("Index", "Appointment")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">Appointments</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-1 bg-light" style="font-size: 0.85rem; margin-top: 30px;">
        <div class="container text-center">
            &copy; 2025 - Student's ID - Nguyen Tan Manh
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
